# Copia este archivo como .env y completa los valores reales de este servidor.
# El .env real NUNCA se sube a git (ver .gitignore) porque tiene credenciales.

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=AXENTRA
DB_USER=postgres
DB_PASSWORD=cambia-esto

# API
# Genera una clave nueva y distinta para cada entorno (no reutilices la de desarrollo).
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Server
# 0.0.0.0 para que el backend se pueda alcanzar desde otras maquinas de la red;
# 127.0.0.1 si el servidor solo se va a usar desde la misma maquina.
HOST=0.0.0.0
PORT=8010

# Email (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_app
FROM_EMAIL=tu_email@gmail.com
